# Copy to .env.local and fill in values. Never commit .env.local.

# Convex (auto-filled by `npx convex dev`)
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=
CONVEX_DEPLOYMENT=

# Groq API — https://console.groq.com/keys (set in Convex dashboard)
GROQ_API_KEY=

# Legacy (unused if Groq is configured)
GEMINI_API_KEY=

# Serper Images API — https://serper.dev (one-time incident image backfill)
# npx convex env set SERPER_API_KEY <key>
SERPER_API_KEY=

# Convex Auth — where users land after OAuth (no trailing slash)
# Dev: match your Next.js port exactly (3000 or 3001), trailing slash OK
# npx convex env set SITE_URL http://localhost:3001/

# Google OAuth — set in Convex (not in this file)
# 1. Google Cloud Console → APIs & Services → Credentials → OAuth client (Web)
# 2. Authorized redirect URI (from Convex dashboard → Settings → URL & Deploy Key):
#    https://<your-deployment>.convex.site/api/auth/callback/google
# 3. Authorized JavaScript origins: http://localhost:3000, http://localhost:3001, production URL
# npx convex env set AUTH_GOOGLE_ID <client-id>
# npx convex env set AUTH_GOOGLE_SECRET <client-secret>
# For production: add --prod to the commands above and set SITE_URL to your Vercel URL

# Optional
GEMINI_PROJECT_NUMBER=
DEMO_MODE=false
