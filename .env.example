# Copy to .env.local and fill in values. Never commit .env.local.

# Convex (auto-filled by `npx convex dev`)
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=
CONVEX_DEPLOYMENT=

# Groq API — https://console.groq.com/keys (set in Convex dashboard)
GROQ_API_KEY=

# Legacy (unused if Groq is configured)
GEMINI_API_KEY=

# Serper Images API — https://serper.dev (one-time incident image backfill)
# npx convex env set SERPER_API_KEY <key>
SERPER_API_KEY=

# Convex Auth — required for Google OAuth redirect
SITE_URL=http://localhost:3000

# Google OAuth (set in Convex dashboard or via CLI)
# npx convex env set AUTH_GOOGLE_ID <client-id>
# npx convex env set AUTH_GOOGLE_SECRET <client-secret>
# Redirect URI: https://<deployment>.convex.site/api/auth/callback/google

# Optional
GEMINI_PROJECT_NUMBER=
DEMO_MODE=false
